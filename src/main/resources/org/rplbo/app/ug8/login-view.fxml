<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--Buatlah Semirip mungkin, bebas asalkan jalan-->

<AnchorPane prefHeight="322.0" prefWidth="438.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.rplbo.app.ug8.Controller.LoginController">
   <children>
      <Label layoutX="71.0" layoutY="37.0" prefHeight="43.0" prefWidth="295.0" text="UMBRELLA CORP - SECTOR B" textAlignment="CENTER">
